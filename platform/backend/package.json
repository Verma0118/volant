{
  "name": "volant-backend",
  "private": true,
  "version": "0.1.0",
  "type": "commonjs",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon --legacy-watch src/index.js",
    "start": "node src/index.js",
    "migrate": "DATABASE_URL=${DATABASE_URL:-postgres://postgres:postgres@localhost:5432/volant} node-pg-migrate up -m \"migrations/*.js\" --use-glob --check-order false",
    "migrate:strict": "DATABASE_URL=${DATABASE_URL:-postgres://postgres:postgres@localhost:5432/volant} node-pg-migrate up -m migrations",
    "migrate:down": "DATABASE_URL=${DATABASE_URL:-postgres://postgres:postgres@localhost:5432/volant} node-pg-migrate down -m \"migrations/*.js\" --use-glob --check-order false",
    "seed": "node src/seed.js",
    "simulator": "node simulator/index.js",
    "telemetry:watch": "node scripts/watchTelemetry.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "pg": "^8.16.3",
    "redis": "^4.7.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "node-pg-migrate": "^8.0.4"
  }
}

