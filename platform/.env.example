# Copy to .env for local dev. CHANGE POSTGRES_PASSWORD and REDIS_PASSWORD
# before any shared deployment. docker-compose.yml reads these values.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_before_deploy
POSTGRES_DB=volant
REDIS_PASSWORD=change_me_before_deploy
DATABASE_URL=postgres://postgres:change_me_before_deploy@localhost:5432/volant
REDIS_URL=redis://:change_me_before_deploy@localhost:6379
VITE_MAPBOX_TOKEN=
PORT=3001
DEMO_MODE=false
CURRENT_OPERATOR_ID=
JWT_SECRET=change_me_before_deploy

FRONTEND_ORIGIN=http://127.0.0.1:5173
SECURITY_HARDENED=false
ALLOW_MISSING_ORIGIN=true
JWT_COOKIE_NAME=volant_auth
